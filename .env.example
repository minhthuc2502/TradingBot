# ──────────────────────────────────────────────────────────────────────────
# Application
# ──────────────────────────────────────────────────────────────────────────
APP_NAME=TradingBot
DEBUG=false
HOST=0.0.0.0
PORT=8000

# ──────────────────────────────────────────────────────────────────────────
# Database  (SQLite path; swap for postgres://... for production)
# ──────────────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///./data/tradingbot.db

# ──────────────────────────────────────────────────────────────────────────
# LLM Provider
# Supported: openai | google | anthropic | xai | openrouter | ollama
# ──────────────────────────────────────────────────────────────────────────
LLM_PROVIDER=openai
DEEP_THINK_LLM=gpt-4o
QUICK_THINK_LLM=gpt-4o-mini
MAX_DEBATE_ROUNDS=1
ONLINE_TOOLS=true

# ──────────────────────────────────────────────────────────────────────────
# LLM API Keys  — set at least the one matching LLM_PROVIDER above
# ──────────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
GOOGLE_API_KEY=
ANTHROPIC_API_KEY=
XAI_API_KEY=

# Alpha Vantage is used by TradingAgents for fundamental data
ALPHA_VANTAGE_API_KEY=

# ──────────────────────────────────────────────────────────────────────────
# Twilio WhatsApp
# Sign up at https://www.twilio.com, enable the WhatsApp sandbox or
# a registered number, and fill in the values below.
# ──────────────────────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Your Twilio WhatsApp sender number (include the "whatsapp:" prefix)
# Sandbox default: whatsapp:+14155238886
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# ──────────────────────────────────────────────────────────────────────────
# Authorised WhatsApp recipients
# Comma-separated numbers with country code (e.g. +12025551234,+33612345678)
# Leave empty to allow ALL numbers — not recommended for production.
# ──────────────────────────────────────────────────────────────────────────
AUTHORIZED_NUMBERS=+12025551234

# ──────────────────────────────────────────────────────────────────────────
# Discord Bot  (optional — leave blank to disable Discord integration)
#
# 1. Create an app + bot at https://discord.com/developers/applications
# 2. Under Bot → Privileged Gateway Intents, enable "Message Content Intent"
# 3. Invite the bot with scopes: bot  +  permissions: Send Messages, Read Messages
# 4. Copy the Bot Token below and the ID of the channel for broadcast notifications
# ──────────────────────────────────────────────────────────────────────────
DISCORD_BOT_TOKEN=
# Right-click a channel in Discord (Developer Mode on) → Copy Channel ID
DISCORD_CHANNEL_ID=0
# Comma-separated Discord user IDs allowed to send commands; empty = allow all
DISCORD_AUTHORIZED_USER_IDS=

# ──────────────────────────────────────────────────────────────────────────
# Scheduler
# HH:MM in the configured timezone (UTC recommended)
# ──────────────────────────────────────────────────────────────────────────
ANALYSIS_TIME=12:00
ANALYSIS_TIMEZONE=UTC

# ──────────────────────────────────────────────────────────────────────────
# Concurrency guard
# Max number of stocks analysed in parallel (each uses multiple LLM calls)
# ──────────────────────────────────────────────────────────────────────────
MAX_CONCURRENT_ANALYSES=2

# ──────────────────────────────────────────────────────────────────────────
# Default watchlist  (seeded once into the DB on first startup)
# Comma-separated tickers; you can change the live list via WhatsApp commands
# ──────────────────────────────────────────────────────────────────────────
DEFAULT_WATCHLIST=AAPL,MSFT,NVDA,GOOGL

# ── Stock Discovery ───────────────────────────────────────────────────────
DISCOVERY_ENABLED=false
DISCOVERY_UNIVERSE=sp500         # sp500 | nasdaq100 | custom
DISCOVERY_CUSTOM_UNIVERSE=       # comma-separated tickers (if DISCOVERY_UNIVERSE=custom)
DISCOVERY_MAX_TICKERS=10         # max auto-discovered tickers per day
DISCOVERY_TIME=23:00             # UTC HH:MM — runs evening before analysis
